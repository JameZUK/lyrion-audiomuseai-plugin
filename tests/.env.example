# Copy this file to tests/.env and fill in your AudioMuse-AI bearer
# token. tests/.env is .gitignored — never commit it.
#
# Mint a token in the AudioMuse web UI: Administration → Tokens.

AUDIOMUSE_TOKEN=paste_your_token_here

# Optional: defaults to http://mediastream.int.jmuk.co.uk:8000.
# AUDIOMUSE_URL=http://your-host:8000
